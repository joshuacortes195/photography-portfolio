# Copy this file to .env.local and fill in the values. See SETUP-DRIVE.md.

# Google Cloud API key with the Drive API enabled. Used to list each member's
# public Drive folder. Required for galleries to show up.
GOOGLE_DRIVE_API_KEY=

# Any random string. Lets you force an instant gallery refresh by POSTing to
# /api/revalidate?secret=THIS_VALUE. Optional.
REVALIDATE_SECRET=

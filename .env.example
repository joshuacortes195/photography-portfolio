# Copy this file to .env.local and fill in the values. See SETUP-DRIVE.md.

# Google Cloud API key with the Drive API enabled. Used to list each member's
# public Drive folder. Required for galleries to show up.
GOOGLE_DRIVE_API_KEY=

# Any random string. Lets you force an instant gallery refresh by POSTing to
# /api/revalidate?secret=THIS_VALUE. Optional.
REVALIDATE_SECRET=

# Web3Forms access key (https://web3forms.com — free). Powers the Contact Us
# form: visitor messages are emailed to afterimage.thirds@gmail.com. Get a key
# by entering that address on web3forms.com, then paste it here.
#
# NEXT_PUBLIC_ on purpose: Web3Forms' free plan only accepts submissions from
# the visitor's browser, so the key is sent client-side. That's by design — the
# key can only deliver mail to the configured inbox and has spam filtering.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
